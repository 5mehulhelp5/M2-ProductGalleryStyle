<?xml version="1.0"?>
<!--
/**
 * Rollpix ProductGallery Frontend Dependency Injection
 *
 * @category  Rollpix
 * @package   Rollpix_ProductGallery
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Swap img for video on product listing pages -->
    <type name="Magento\Catalog\Block\Product\Image">
        <plugin name="rollpix_listing_video_swap"
                type="Rollpix\ProductGallery\Plugin\Catalog\Block\Product\ImagePlugin"/>
    </type>

    <!-- Attach product reference to Image block for video detection -->
    <type name="Magento\Catalog\Block\Product\ImageFactory">
        <plugin name="rollpix_image_factory_product_ref"
                type="Rollpix\ProductGallery\Plugin\Catalog\Block\Product\ImageFactoryPlugin"/>
    </type>

    <!-- Batch-load video data for listing products AFTER toolbar applied pageSize -->
    <type name="Magento\Catalog\Block\Product\ListProduct">
        <plugin name="rollpix_listing_add_video_data"
                type="Rollpix\ProductGallery\Plugin\Catalog\Block\Product\ListProduct\AddVideoDataPlugin"/>
    </type>


    <!-- Amasty_Label compatibility: register the Rollpix vertical gallery block
         name so Amasty's afterToHtml plugin renders PDP labels for it -->
    <type name="Amasty\Label\Plugin\Catalog\Product\View\Label">
        <arguments>
            <argument name="allowedNames" xsi:type="array">
                <item name="rollpix_gallery_vertical" xsi:type="string">rollpix.product.gallery.vertical</item>
            </argument>
        </arguments>
    </type>

</config>

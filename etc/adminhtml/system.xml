<?xml version="1.0"?>
<!--
/**
 * Rollpix ProductGallery Admin System Configuration
 *
 * @category  Rollpix
 * @package   Rollpix_ProductGallery
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="rollpix" translate="label" sortOrder="400">
            <label>Rollpix</label>
        </tab>

        <section id="rollpix_gallery"
                 translate="label"
                 type="text"
                 sortOrder="10"
                 showInDefault="1"
                 showInWebsite="1"
                 showInStore="1">
            <label>Product Gallery</label>
            <tab>rollpix</tab>
            <resource>Rollpix_ProductGallery::config</resource>

            <!-- Zoom Group -->
            <group id="zoom"
                   translate="label"
                   type="text"
                   sortOrder="20"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>Zoom Settings</label>

                <field id="type"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Zoom Type</label>
                    <comment>Select the zoom behavior: Hover Magnifier, Lightbox (GLightbox), Click to Zoom, Modal Zoom (full-screen image stack), or Disabled</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ZoomType</source_model>
                </field>

                <field id="level"
                       translate="label comment"
                       type="select"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Zoom Level</label>
                    <comment>Magnification level for hover and click zoom</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ZoomLevel</source_model>
                    <depends>
                        <field id="type" separator=",">hover,click</field>
                    </depends>
                </field>

                <field id="position"
                       translate="label comment"
                       type="select"
                       sortOrder="30"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Zoom Window Position</label>
                    <comment>Position of the magnified view (only for hover zoom)</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ZoomPosition</source_model>
                    <depends>
                        <field id="type">hover</field>
                    </depends>
                </field>
            </group>

            <!-- Video Group -->
            <group id="video"
                   translate="label"
                   type="text"
                   sortOrder="15"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>Video Settings</label>

                <field id="enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enable Video Support</label>
                    <comment>Allow MP4, YouTube and Vimeo videos in the product gallery</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <!-- PDP Video Settings -->
                <field id="autoplay"
                       translate="label comment"
                       type="select"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>PDP Autoplay</label>
                    <comment>Automatically play videos when they become visible on the product detail page</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="loop"
                       translate="label comment"
                       type="select"
                       sortOrder="30"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Loop</label>
                    <comment>Restart the video automatically when it ends</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="muted"
                       translate="label comment"
                       type="select"
                       sortOrder="40"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Muted</label>
                    <comment>Mute video audio. Required for autoplay in most browsers.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="controls"
                       translate="label comment"
                       type="select"
                       sortOrder="50"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>PDP Player Controls</label>
                    <comment>Display the native video player controls on the product detail page (play, pause, volume, etc.)</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="player_size"
                       translate="label comment"
                       type="select"
                       sortOrder="55"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>PDP Player Size</label>
                    <comment>Whether the video player uses the video's native 16:9 proportion or matches the aspect ratio of the product images</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ListingPlayerSize</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="object_fit"
                       translate="label comment"
                       type="select"
                       sortOrder="60"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>PDP Video Fit Mode</label>
                    <comment>How the video fits its container on the product detail page. Cover: crops to fill. Contain: shows entire video with possible letterboxing.</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\VideoObjectFit</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="lazy_load"
                       translate="label comment"
                       type="select"
                       sortOrder="70"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Lazy Load Videos</label>
                    <comment>Only load video data when the video enters the viewport. Improves page load performance.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="max_size"
                       translate="label comment"
                       type="select"
                       sortOrder="80"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Maximum Video File Size (MB)</label>
                    <comment>Maximum allowed file size for MP4 video uploads in the product media gallery</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\VideoMaxSize</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <!-- Listing Video Settings -->
                <field id="listing_enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="90"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enable Video on Category Pages</label>
                    <comment>Show product videos on category listing pages. Detects videos from the product media gallery (prioritizes video with small_image role).</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="listing_autoplay"
                       translate="label comment"
                       type="select"
                       sortOrder="100"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Listing Autoplay</label>
                    <comment>Automatically play videos on category listing pages when visible. Recommended only when few products have videos.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="listing_enabled">1</field>
                    </depends>
                </field>

                <field id="listing_controls"
                       translate="label comment"
                       type="select"
                       sortOrder="110"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Listing Play/Stop Button</label>
                    <comment>Show a simplified play/stop button overlay on listing page videos</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="listing_enabled">1</field>
                    </depends>
                </field>

                <field id="listing_player_size"
                       translate="label comment"
                       type="select"
                       sortOrder="120"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Listing Player Size</label>
                    <comment>Whether the video player matches the image dimensions of other products or uses the video's native 16:9 proportion</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ListingPlayerSize</source_model>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="listing_enabled">1</field>
                    </depends>
                </field>

                <field id="listing_video_fit"
                       translate="label comment"
                       type="select"
                       sortOrder="130"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Listing Video Fit</label>
                    <comment>Show the complete video (with letterbox if needed) or crop from center to fill the player</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\VideoObjectFit</source_model>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="listing_enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Layout Group -->
            <group id="layout"
                   translate="label"
                   type="text"
                   sortOrder="10"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>Layout Settings</label>

                <field id="type"
                       translate="label comment"
                       type="select"
                       sortOrder="5"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Layout Type</label>
                    <comment>Vertical: single column of images. Grid: multi-column image grid with info sidebar.</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\LayoutType</source_model>
                </field>

                <field id="gallery_position"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Gallery Position</label>
                    <comment>Position of the image gallery relative to product info</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\GalleryPosition</source_model>
                </field>

                <field id="column_ratio"
                       translate="label comment"
                       type="select"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Column Ratio</label>
                    <comment>Width ratio between gallery and product info columns (vertical layout)</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ColumnRatio</source_model>
                    <depends>
                        <field id="type">vertical</field>
                    </depends>
                </field>

                <field id="grid_ratio"
                       translate="label comment"
                       type="select"
                       sortOrder="25"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Grid Ratio</label>
                    <comment>Width ratio between image grid and product info sidebar (grid layout)</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\GridRatio</source_model>
                    <depends>
                        <field id="type" separator=",">grid,fashion,slider</field>
                    </depends>
                </field>

                <field id="grid_image_columns"
                       translate="label comment"
                       type="select"
                       sortOrder="26"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Image Columns in Grid</label>
                    <comment>Number of image columns within the grid area</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\GridImageColumns</source_model>
                    <depends>
                        <field id="type">grid</field>
                    </depends>
                </field>

                <field id="image_gap"
                       translate="label comment"
                       type="select"
                       sortOrder="30"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Gap Between Images</label>
                    <comment>Space between images in the gallery (in pixels)</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ImageGap</source_model>
                </field>

                <field id="slider_direction"
                       translate="label comment"
                       type="select"
                       sortOrder="36"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Slider Direction</label>
                    <comment>Direction of slide transition when navigating between images</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\SliderDirection</source_model>
                    <depends>
                        <field id="type">slider</field>
                    </depends>
                </field>

                <field id="slider_transition"
                       translate="label comment"
                       type="select"
                       sortOrder="37"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Slider Transition</label>
                    <comment>Visual effect when switching between images</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\SliderTransition</source_model>
                    <depends>
                        <field id="type">slider</field>
                    </depends>
                </field>

                <field id="slider_arrows"
                       translate="label comment"
                       type="select"
                       sortOrder="38"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Slider Navigation Arrows</label>
                    <comment>Show prev/next arrow buttons on the slider</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="type">slider</field>
                    </depends>
                </field>

                <field id="slider_dots"
                       translate="label comment"
                       type="select"
                       sortOrder="39"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Slider Dot Indicators</label>
                    <comment>Show dot indicators below the slider for navigation</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="type">slider</field>
                    </depends>
                </field>

                <field id="slider_mousewheel"
                       translate="label comment"
                       type="select"
                       sortOrder="40"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Mouse Wheel Navigation</label>
                    <comment>Allow scrolling the mouse wheel over the image to switch slides</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="type">slider</field>
                    </depends>
                </field>

                <field id="thumbnail_position"
                       translate="label comment"
                       type="select"
                       sortOrder="45"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Thumbnail Navigation</label>
                    <comment>Show a strip of small thumbnail images for quick navigation. Desktop only. Only available for Slider layout.</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ThumbnailPosition</source_model>
                    <depends>
                        <field id="type">slider</field>
                    </depends>
                </field>

                <field id="thumbnail_style"
                       translate="label comment"
                       type="select"
                       sortOrder="46"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Thumbnail Display Style</label>
                    <comment>Outside: thumbnails appear beside the image. Overlay: thumbnails and dots float inside the image.</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ThumbnailStyle</source_model>
                    <depends>
                        <field id="type">slider</field>
                        <field id="thumbnail_position" separator=",">left,right,bottom</field>
                    </depends>
                </field>

                <field id="thumbnail_shape"
                       translate="label comment"
                       type="select"
                       sortOrder="47"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Thumbnail Shape</label>
                    <comment>Square: thumbnails are cropped to a square. Preserve: thumbnails keep the original image aspect ratio.</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\ThumbnailShape</source_model>
                    <depends>
                        <field id="type">slider</field>
                        <field id="thumbnail_position" separator=",">left,right,bottom</field>
                    </depends>
                </field>
            </group>

            <!-- Effects & Animations Group -->
            <group id="effects"
                   translate="label"
                   type="text"
                   sortOrder="35"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>Effects &amp; Animations</label>

                <field id="shimmer_enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Shimmer Loading Effect</label>
                    <comment>Show animated shimmer placeholder while images are loading</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="fadein_enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Fade-in on Scroll</label>
                    <comment>Subtle opacity and slide-up animation when images enter the viewport. Not available when shimmer is enabled.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="shimmer_enabled">0</field>
                    </depends>
                </field>

                <field id="counter_enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="30"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Image Counter</label>
                    <comment>Show position indicator while navigating images. Only effective with Slider layout.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="focus_style"
                       translate="label comment"
                       type="select"
                       sortOrder="40"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Scroll Focus Effect</label>
                    <comment>Highlight the image closest to the viewport center while fading or blurring images that scroll away. Only for stack layouts (Vertical, Grid, Fashion).</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\FocusStyle</source_model>
                </field>
            </group>

            <!-- Mobile Group -->
            <group id="mobile"
                   translate="label"
                   type="text"
                   sortOrder="90"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>Mobile Settings</label>

                <field id="behavior"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Mobile Behavior</label>
                    <comment>How images are displayed on mobile devices</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\MobileBehavior</source_model>
                </field>

                <field id="carousel_dots"
                       translate="label comment"
                       type="select"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Carousel Dots</label>
                    <comment>Show dot indicators in mobile carousel</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="behavior">carousel</field>
                    </depends>
                </field>

                <field id="carousel_arrows"
                       translate="label comment"
                       type="select"
                       sortOrder="30"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Carousel Arrows</label>
                    <comment>Show prev/next arrows in mobile carousel</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="behavior">carousel</field>
                    </depends>
                </field>
            </group>

            <!-- Tabs Group -->
            <group id="tabs"
                   translate="label"
                   type="text"
                   sortOrder="25"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>Product Tabs</label>

                <field id="inline_enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Inline Accordion Tabs</label>
                    <comment>Move product detail tabs (Description, Additional Info, Reviews) inside the product info column as collapsible accordion sections</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="description_max_height"
                       translate="label comment"
                       type="text"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Description Max Height (px)</label>
                    <comment>Maximum visible height for description content before showing "Read more" link. Set 0 to disable truncation.</comment>
                    <validate>validate-digits</validate>
                    <depends>
                        <field id="inline_enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Sticky Group -->
            <group id="sticky"
                   translate="label"
                   type="text"
                   sortOrder="30"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>Sticky Panel Settings</label>

                <field id="enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enable Sticky</label>
                    <comment>Keep product info panel fixed while scrolling through images</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="mode"
                       translate="label comment"
                       type="select"
                       sortOrder="15"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Sticky Mode</label>
                    <comment>Frame: info scrolls inside a fixed-height panel. Natural scroll: info scrolls with the page and sticks when its bottom reaches the viewport bottom.</comment>
                    <source_model>Rollpix\ProductGallery\Model\Config\Source\StickyMode</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>

                <field id="offset"
                       translate="label comment"
                       type="text"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Top Offset (px)</label>
                    <comment>Distance from top of viewport when sticky (useful for fixed headers)</comment>
                    <validate>validate-digits</validate>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- Configurable Products Group -->
            <group id="configurable"
                   translate="label"
                   type="text"
                   sortOrder="95"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>Configurable Products</label>

                <field id="swatch_gallery_switch_enabled"
                       translate="label comment"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Swatch Gallery Image Switch (Light Mode)</label>
                    <comment><![CDATA[
                        <strong>Light mode:</strong> Replaces the gallery images when the customer selects a different swatch option on a configurable product's PDP.
                        <br/><br/>
                        <strong>LIMITED FEATURE — known limitations:</strong>
                        <ul style="margin-left:18px;list-style:disc">
                            <li>Incompatible with the hover/click zoom widgets — zoom state will not re-initialize on the new variant images. Recommended: disable Zoom or set Zoom Type to "Lightbox" / "Modal Zoom" on configurable PDPs.</li>
                            <li>Videos are not shown on variants (only still images are switched).</li>
                            <li>If the site uses the MageFan WebP plugin (<code>mfwebp</code>) or Yireo WebP2, variant images may be served as non-WebP originals (the <code>&lt;picture&gt;</code> wrapper is not regenerated for the new variant's URLs).</li>
                            <li>Slider / thumbnail / sticky widgets bound to the original DOM are <strong>not</strong> re-initialized for the new images and may behave unexpectedly after a swatch change.</li>
                        </ul>
                        <strong>For full support</strong> (with proper widget teardown, WebP regeneration and video variants) install <a href="https://github.com/ROLLPIX/M2-ConfigurableGallery" target="_blank"><code>Rollpix_ConfigurableGallery</code></a> — when that module is installed this light-mode bridge automatically deactivates itself.
                    ]]></comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- Module Info Group -->
            <group id="info"
                   translate="label"
                   type="text"
                   sortOrder="100"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

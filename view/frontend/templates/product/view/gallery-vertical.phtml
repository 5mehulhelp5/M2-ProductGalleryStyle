<?php
/**
 * Rollpix ProductGallery - Gallery Template
 *
 * @category  Rollpix
 * @package   Rollpix_ProductGallery
 * @var \Magento\Catalog\Block\Product\View\Gallery $block
 * @var \Rollpix\ProductGallery\ViewModel\GalleryConfig $galleryConfig
 */

declare(strict_types=1);

/** @var \Magento\Catalog\Model\Product $product */
$product = $block->getProduct();

if (!$product) {
    return;
}

$productName = $block->escapeHtml($product->getName());

/** @var \Magento\Framework\Data\Collection $images */
$rawImages = $product->getMediaGalleryImages();

// Reorder gallery so the image with the "base" role appears first
$baseImageFile = $product->getData('image'); // file path of image with base role
$imageItems = [];
$baseItem = null;

if ($rawImages) {
    foreach ($rawImages as $img) {
        if ($baseImageFile && $img->getData('file') === $baseImageFile && !$baseItem) {
            $baseItem = $img;
        } else {
            $imageItems[] = $img;
        }
    }
    if ($baseItem) {
        array_unshift($imageItems, $baseItem);
    }
}

// Detect placeholder mode when product has no images
$isPlaceholder = (empty($imageItems));
$placeholderUrl = '';

if ($isPlaceholder) {
    // Use Magento's built-in placeholder fallback from the Gallery block
    $galleryDataJson = $block->getGalleryImagesJson();
    $galleryData = json_decode($galleryDataJson, true);
    $placeholderUrl = !empty($galleryData[0]['img']) ? $galleryData[0]['img'] : '';
    if (empty($placeholderUrl)) {
        return;
    }
}

// Get ViewModel
/** @var \Rollpix\ProductGallery\ViewModel\GalleryConfig $galleryConfig */
$galleryConfig = $block->getData('gallery_config');

// Get configuration from ViewModel
$layoutType = $galleryConfig->getLayoutType();
$zoomType = $galleryConfig->getZoomType();
$zoomLevel = $galleryConfig->getZoomLevel();
$zoomPosition = $galleryConfig->getZoomPosition();
$galleryPosition = $galleryConfig->getGalleryPosition();
$columnRatio = $galleryConfig->getColumnRatio();
$imageGap = $galleryConfig->getImageGap();
$mobileBehavior = $galleryConfig->getMobileBehavior();
$stickyEnabled = $galleryConfig->isStickyEnabled();
$stickyMode = $galleryConfig->getStickyMode();
$stickyOffset = $galleryConfig->getStickyOffset();

// Disable interactive features for placeholder
if ($isPlaceholder) {
    $zoomType = 'disabled';
}

// Build CSS classes
$wrapperClasses = [
    'rp-product-gallery',
    'rp-layout-' . $layoutType,
    'rp-gallery-position-' . $galleryPosition,
    'rp-mobile-' . $mobileBehavior,
    'rp-zoom-' . $zoomType
];

if ($isPlaceholder) {
    $wrapperClasses[] = 'rp-placeholder';
}

if ($stickyEnabled) {
    $wrapperClasses[] = 'rp-sticky-' . $stickyMode;
}

if ($galleryConfig->isInlineTabsEnabled()) {
    $wrapperClasses[] = 'rp-inline-tabs';
}

// Thumbnails only apply to slider layout
$thumbnailPosition = $galleryConfig->getThumbnailPosition();
$thumbnailShape = $galleryConfig->getThumbnailShape();
if ($layoutType === 'slider' && $thumbnailPosition !== 'disabled') {
    $wrapperClasses[] = 'rp-thumbnails-' . $thumbnailPosition;
    if ($galleryConfig->getThumbnailStyle() === 'overlay') {
        $wrapperClasses[] = 'rp-thumbnails-overlay';
    }
    if ($thumbnailShape === 'preserve') {
        $wrapperClasses[] = 'rp-thumbnails-preserve';
    }
}

// Slider navigation
$sliderArrows = $layoutType === 'slider' && $galleryConfig->isSliderArrowsEnabled();
$sliderDots = $layoutType === 'slider' && $galleryConfig->isSliderDotsEnabled();

// Shimmer and fade-in are mutually exclusive; shimmer takes priority
if ($galleryConfig->isShimmerEnabled()) {
    $wrapperClasses[] = 'rp-shimmer';
} elseif ($galleryConfig->isFadeInEnabled()) {
    $wrapperClasses[] = 'rp-fadein';
}

if ($galleryConfig->isCounterEnabled()) {
    $wrapperClasses[] = 'rp-counter';
}

// Focus effect only for stack layouts (not slider)
$focusStyle = $galleryConfig->getFocusStyle();
if ($focusStyle !== 'disabled' && $layoutType !== 'slider') {
    $wrapperClasses[] = 'rp-focus-' . $focusStyle;
}

// Get JS config
$jsConfig = $galleryConfig->getJsConfigJson();

// Get column CSS values
$columnCss = $galleryConfig->getColumnCss();
$gridImageColumns = $columnCss['gridImageColumns'] ?? 2;
?>

<style>
    .rp-product-wrapper {
        --rp-col-1: <?= $block->escapeHtmlAttr($columnCss['col1']) ?>;
        --rp-col-2: <?= $block->escapeHtmlAttr($columnCss['col2']) ?>;
        --rp-gallery-order: <?= (int)$columnCss['galleryOrder'] ?>;
        --rp-info-order: <?= (int)$columnCss['infoOrder'] ?>;
        --rp-sticky-offset: <?= (int)$stickyOffset ?>px;
        --rp-image-gap: <?= (int)$imageGap ?>px;
        <?php if ($layoutType === 'grid'): ?>
        --rp-grid-cols: <?= (int)$gridImageColumns ?>;
        <?php endif; ?>
    }
    <?php if (!$stickyEnabled): ?>
    .rp-product-wrapper .product-info-main {
        position: static !important;
    }
    <?php elseif ($stickyMode === 'frame'): ?>
    .rp-product-wrapper .product-info-main {
        max-height: calc(100vh - <?= (int)$stickyOffset ?>px - 20px);
        overflow-y: auto;
    }
    <?php else: /* scroll mode */ ?>
    .rp-product-wrapper .product-info-main {
        max-height: none;
        overflow-y: visible;
    }
    <?php endif; ?>
    @media screen and (max-width: 767px) {
        .rp-product-wrapper .product-info-main {
            position: relative !important;
            max-height: none !important;
            overflow-y: visible !important;
        }
    }
</style>

<div class="<?= $block->escapeHtmlAttr(implode(' ', $wrapperClasses)) ?>"
     data-role="rp-gallery"
     data-mage-init='{"rpGalleryZoom": <?= /* @noEscape */ $jsConfig ?>, "rpGalleryCarousel": <?= /* @noEscape */ $jsConfig ?>, "rpGalleryTabs": <?= /* @noEscape */ $jsConfig ?>, "rpGalleryEffects": <?= /* @noEscape */ $jsConfig ?>, "rpGalleryThumbnails": <?= /* @noEscape */ $jsConfig ?>, "rpGallerySlider": <?= /* @noEscape */ $jsConfig ?>, "rpGalleryModalZoom": <?= /* @noEscape */ $jsConfig ?>, "rpGalleryVideo": <?= /* @noEscape */ $jsConfig ?>}'>

    <?php if ($layoutType === 'slider'): ?>
    <div class="rp-slider-wrapper">
    <?php endif; ?>

        <div class="rp-gallery-images">
            <?php if ($isPlaceholder): ?>
                <span class="rp-gallery-item rp-placeholder-item">
                    <img src="<?= $block->escapeUrl($placeholderUrl) ?>"
                         alt="<?= $block->escapeHtmlAttr($productName) ?>"/>
                </span>
            <?php else: ?>
                <?php foreach ($imageItems as $image): ?>
                    <?php
                    $isVideo = $galleryConfig->isVideoEnabled()
                        && $image->getData('media_type') === 'external-video';
                    $videoProvider = $image->getData('video_provider')
                        ?: ($image->getData('provider') ?: '');
                    $videoUrl = $image->getData('video_url') ?: '';

                    // Fallback: detect provider from video URL when not set by Magento
                    if ($isVideo && empty($videoProvider) && !empty($videoUrl)) {
                        $parsedVideo = $galleryConfig->parseVideoUrl($videoUrl);
                        if ($parsedVideo) {
                            $videoProvider = $parsedVideo['provider'];
                        }
                    }

                    $isLocalVideo = $isVideo && $videoProvider === 'local';
                    $isExternalVideo = $isVideo && $galleryConfig->isExternalVideo($videoProvider);
                    $largeImageUrl = $image->getData('large_image_url') ?: $image->getData('url');
                    $mediumImageUrl = $image->getData('medium_image_url') ?: $image->getData('url');
                    $imageLabel = $image->getData('label') ?: $productName;
                    ?>
                    <?php if ($isLocalVideo): ?>
                        <span class="rp-gallery-item rp-gallery-video"
                              data-media-type="video"
                              data-video-provider="local"
                              data-rp-value-id="<?= (int)$image->getData('value_id') ?>"
                              data-gallery="product-gallery"
                              style="aspect-ratio:<?= $block->escapeHtmlAttr($galleryConfig->getPdpVideoAspectRatio($product)) ?>">
                            <video
                                <?php if ($galleryConfig->isVideoAutoplay()): ?>autoplay<?php endif; ?>
                                <?php if ($galleryConfig->isVideoLoop()): ?>loop<?php endif; ?>
                                <?php if ($galleryConfig->isVideoMuted()): ?>muted<?php endif; ?>
                                <?php if ($galleryConfig->isVideoControlsEnabled()): ?>controls<?php endif; ?>
                                playsinline
                                preload="<?= $galleryConfig->isVideoLazyLoad() ? 'none' : 'metadata' ?>"
                                class="rp-video-element"
                                style="object-fit: <?= $block->escapeHtmlAttr($galleryConfig->getVideoObjectFit()) ?>"
                            >
                                <source src="<?= $block->escapeUrl($image->getData('url')) ?>" type="video/mp4"/>
                            </video>
                        </span>
                    <?php elseif ($isExternalVideo && $videoUrl): ?>
                        <?php
                        $embedUrl = $galleryConfig->getVideoEmbedUrl($videoUrl, $videoProvider);
                        $thumbnailUrl = $mediumImageUrl;
                        $lazyLoad = $galleryConfig->isVideoLazyLoad();
                        ?>
                        <span class="rp-gallery-item rp-gallery-video rp-gallery-video-external"
                              data-media-type="video"
                              data-video-provider="<?= $block->escapeHtmlAttr($videoProvider) ?>"
                              data-video-embed-url="<?= $block->escapeHtmlAttr($embedUrl) ?>"
                              data-rp-value-id="<?= (int)$image->getData('value_id') ?>"
                              data-gallery="product-gallery"
                              style="aspect-ratio:<?= $block->escapeHtmlAttr($galleryConfig->getPdpVideoAspectRatio($product)) ?>">
                            <?php if ($lazyLoad): ?>
                                <div class="rp-video-facade"
                                     style="background-image: url('<?= $block->escapeUrl($thumbnailUrl) ?>')">
                                    <button class="rp-video-facade-play" type="button"
                                            aria-label="<?= $block->escapeHtmlAttr(__('Play video')) ?>">
                                        <svg width="64" height="64" viewBox="0 0 64 64">
                                            <circle cx="32" cy="32" r="30" fill="rgba(0,0,0,0.65)"/>
                                            <polygon points="26,18 26,46 48,32" fill="#fff"/>
                                        </svg>
                                    </button>
                                </div>
                            <?php else: ?>
                                <iframe src="<?= $block->escapeUrl($embedUrl) ?>"
                                        class="rp-video-iframe"
                                        frameborder="0"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                        referrerpolicy="strict-origin-when-cross-origin"
                                        allowfullscreen
                                        loading="lazy">
                                </iframe>
                            <?php endif; ?>
                        </span>
                    <?php else: ?>
                        <a href="<?= $block->escapeUrl($largeImageUrl) ?>"
                           class="rp-gallery-item <?= $zoomType === 'lightbox' ? 'glightbox' : '' ?>"
                           data-media-type="image"
                           data-rp-value-id="<?= (int)$image->getData('value_id') ?>"
                           data-gallery="product-gallery"
                           <?php if ($zoomType === 'lightbox'): ?>
                           data-glightbox="title: <?= $block->escapeHtmlAttr($imageLabel) ?>"
                           <?php endif; ?>>
                            <img src="<?= $block->escapeUrl($mediumImageUrl) ?>"
                                 alt="<?= $block->escapeHtmlAttr($imageLabel) ?>"
                                 loading="lazy"/>
                        </a>
                    <?php endif; ?>
                <?php endforeach; ?>
            <?php endif; ?>
        </div>

    <?php if ($layoutType === 'slider'): ?>
        <?php if ($sliderArrows && !$isPlaceholder): ?>
        <button class="rp-slider-prev" type="button" aria-label="<?= $block->escapeHtmlAttr(__('Previous image')) ?>">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="rp-slider-next" type="button" aria-label="<?= $block->escapeHtmlAttr(__('Next image')) ?>">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <?php endif; ?>
        <?php if ($sliderDots && !$isPlaceholder): ?>
        <div class="rp-slider-dots" data-role="rp-slider-dots"></div>
        <?php endif; ?>
    </div><!-- /.rp-slider-wrapper -->
    <?php endif; ?>

    <?php if ($layoutType === 'slider' && $thumbnailPosition !== 'disabled' && !$isPlaceholder): ?>
    <div class="rp-thumbnail-strip" data-role="rp-thumbnails">
        <?php foreach ($imageItems as $index => $image): ?>
            <?php
            $isThumbVideo = $galleryConfig->isVideoEnabled()
                && $image->getData('media_type') === 'external-video';
            $thumbVideoProvider = $image->getData('video_provider')
                ?: ($image->getData('provider') ?: '');
            $thumbVideoUrl = $image->getData('video_url') ?: '';
            if ($isThumbVideo && empty($thumbVideoProvider) && !empty($thumbVideoUrl)) {
                $parsedThumb = $galleryConfig->parseVideoUrl($thumbVideoUrl);
                if ($parsedThumb) {
                    $thumbVideoProvider = $parsedThumb['provider'];
                }
            }
            $isThumbLocalVideo = $isThumbVideo && $thumbVideoProvider === 'local';
            $isThumbExternalVideo = $isThumbVideo && $galleryConfig->isExternalVideo($thumbVideoProvider);
            $thumbUrl = $image->getData('small_image_url') ?: $image->getData('url');
            $thumbLabel = $image->getData('label') ?: $productName;
            ?>
            <button class="rp-thumbnail-item<?= $index === 0 ? ' rp-thumbnail-active' : '' ?><?= $isThumbVideo ? ' rp-thumbnail-video' : '' ?>"
                    type="button"
                    data-thumb-index="<?= (int)$index ?>"
                    data-rp-value-id="<?= (int)$image->getData('value_id') ?>"
                    data-media-type="<?= $isThumbVideo ? 'video' : 'image' ?>"
                    aria-label="<?= $block->escapeHtmlAttr(__('Go to %1 %2', $isThumbVideo ? __('video') : __('image'), $index + 1)) ?>">
                <?php if ($isThumbVideo): ?>
                <span class="rp-thumbnail-play-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><polygon points="5,3 19,12 5,21"/></svg>
                </span>
                <?php endif; ?>
                <?php if ($isThumbLocalVideo): ?>
                    <video muted preload="metadata" class="rp-thumbnail-video-preview">
                        <source src="<?= $block->escapeUrl($image->getData('url')) ?>#t=0.5" type="video/mp4"/>
                    </video>
                <?php else: ?>
                    <img src="<?= $block->escapeUrl($thumbUrl) ?>"
                         alt="<?= $block->escapeHtmlAttr($thumbLabel) ?>"
                         loading="lazy"/>
                <?php endif; ?>
            </button>
        <?php endforeach; ?>
    </div>
    <?php endif; ?>
</div>
